{
  "name": "heimajizhang",
  "version": "1.0.0",
  "description": "记账 - 个人桌面记账应用",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "node scripts/build-electron.mjs && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 node scripts/start-electron.mjs .",
    "dev": "node scripts/build-electron.mjs && concurrently --kill-others \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 node scripts/start-electron.mjs .\"",
    "electron": "node scripts/start-electron.mjs",
    "build:renderer": "vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "build": "npm run build:electron && npm run build:renderer",
    "preview": "vite preview",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:all": "npm run build && electron-builder --win --mac"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "antd": "^5.29.3",
    "dayjs": "^1.11.21",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "wait-on": "^9.0.10"
  }
}
